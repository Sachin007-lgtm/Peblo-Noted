# ==========================================
# Frontend Environment Variables (Place in frontend/.env)
# ==========================================

# Your Supabase Project URL and Anon Public Key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ==========================================
# Backend Environment Variables (Place in backend/.env)
# ==========================================

# Your Groq API Key (kept secret on the server)
GROQ_API_KEY=gsk_your_groq_api_key_here

# (Optional) Port for the Express server to run on
PORT=3000
